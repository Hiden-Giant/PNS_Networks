# PostgreSQL connection used by the application and Prisma CLI.
DATABASE_URL="postgresql://neondb_owner:change-me@ep-example-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"

# Generate with: openssl rand -base64 32
SESSION_SECRET="replace-with-at-least-32-random-characters"

# Optional bootstrap account used only by `npm run db:seed`.
SEED_ADMIN_EMAIL="admin@pns.co.kr"
SEED_ADMIN_NAME="초기 관리자"
SEED_ADMIN_PASSWORD="replace-with-a-strong-password"
